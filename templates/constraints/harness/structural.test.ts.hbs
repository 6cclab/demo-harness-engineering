import { readFileSync, readdirSync, statSync } from 'node:fs';
import { join, relative, resolve } from 'node:path';
import { describe, expect, it } from 'vitest';
import { APPS, BACKEND_APPS, CLIENT_ONLY_PACKAGES, PACKAGES, isImportAllowed } from './import-rules.js';

const ROOT = resolve(import.meta.dirname, '../../..');

const APP_SRC_DIRS: Record<string, string> = {
{{#each apps}}
  '{{this.name}}': '{{this.srcDir}}',
{{/each}}
};

function collectSourceFiles(dir: string): string[] {
  const files: string[] = [];
  let entries: string[];
  try { entries = readdirSync(dir); } catch { return files; }
  for (const entry of entries) {
    const fullPath = join(dir, entry);
    if (['node_modules', 'dist', 'build', 'generated', '.react-router'].includes(entry)) continue;
    let stat;
    try { stat = statSync(fullPath); } catch { continue; }
    if (stat.isDirectory()) files.push(...collectSourceFiles(fullPath));
    else if (/\.(ts|tsx)$/.test(entry) && !entry.endsWith('.d.ts')) files.push(fullPath);
  }
  return files;
}

function extractImports(filePath: string, scope: string): string[] {
  const content = readFileSync(filePath, 'utf-8');
  const imports: string[] = [];
  const regex = new RegExp(`(?:import|export)\\s+(?:type\\s+)?(?:[\\s\\S]*?)\\s+from\\s+['"](${scope.replace('/', '\\/')}\\/[^'"]+)['"]`, 'g');
  let match: RegExpExecArray | null;
  match = regex.exec(content);
  while (match !== null) { imports.push(match[1]); match = regex.exec(content); }
  return imports;
}

const SCOPE = '{{scope}}';

describe('Import Boundary Enforcement', () => {
  it('packages do not import from apps', () => {
    const violations: string[] = [];
    for (const pkg of PACKAGES) {
      if (pkg === 'harness') continue;
      const pkgDir = join(ROOT, 'packages', pkg, 'src');
      for (const file of collectSourceFiles(pkgDir)) {
        for (const imp of extractImports(file, SCOPE)) {
          const result = isImportAllowed(pkg, imp);
          if (!result.allowed) violations.push(`${relative(ROOT, file)}: ${result.reason}`);
        }
      }
    }
    expect(violations, `Import boundary violations:\n${violations.join('\n')}`).toEqual([]);
  });

  it('backend apps do not import client-only packages', () => {
    const violations: string[] = [];
    for (const app of BACKEND_APPS) {
      const appDir = join(ROOT, 'apps', app, APP_SRC_DIRS[app] ?? 'src');
      for (const file of collectSourceFiles(appDir)) {
        for (const imp of extractImports(file, SCOPE)) {
          const isClientOnly = CLIENT_ONLY_PACKAGES.some((pkg) => imp === pkg || imp.startsWith(`${pkg}/`));
          if (isClientOnly) violations.push(`${relative(ROOT, file)}: imports "${imp}" in backend app "${app}"`);
        }
      }
    }
    expect(violations, `Backend apps importing client-only packages:\n${violations.join('\n')}`).toEqual([]);
  });

  it('cross-app imports are approved', () => {
    const violations: string[] = [];
    for (const app of APPS) {
      const srcDir = join(ROOT, 'apps', app, APP_SRC_DIRS[app] ?? 'src');
      for (const file of collectSourceFiles(srcDir)) {
        for (const imp of extractImports(file, SCOPE)) {
          const result = isImportAllowed(app, imp);
          if (!result.allowed) violations.push(`${relative(ROOT, file)}: ${result.reason}`);
        }
      }
    }
    expect(violations, `Unapproved cross-app imports:\n${violations.join('\n')}`).toEqual([]);
  });
});
