commit_msg=$(cat "$1")

# Conventional commits pattern: type(optional-scope): description
pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .+"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Commit message does not follow conventional commits format."
  echo ""
  echo "Expected: <type>(<optional-scope>): <description>"
  echo ""
  echo "Types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  echo ""
  echo "Examples:"
  echo "  feat: add vehicle analytics dashboard"
  echo "  fix(api): handle null battery state in vehicle data"
  echo "  docs: update AGENTS.md with new package"
  echo "  refactor(event-bus): extract poll worker into separate module"
  echo ""
  echo "Your message: \"$commit_msg\""
  echo ""
  exit 1
fi
