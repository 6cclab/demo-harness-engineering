name: Harness Entropy Scan
on:
  schedule:
    - cron: '{{entropy.ci.schedule}}'
  workflow_dispatch: {} # Allow manual trigger
permissions:
  contents: read
  issues: write
jobs:
  entropy-scan:
    runs-on: [{{entropy.ci.runner}}]
    steps:
      - uses: actions/checkout@v6
      - uses: pnpm/action-setup@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 24
          cache: pnpm
      - run: pnpm install --frozen-lockfile
      - name: Run entropy scanner
        id: scan
        run: |
          output=$(pnpm scan:entropy 2>&1) || true
          echo "scan_output<<EOF" >> "$GITHUB_OUTPUT"
          echo "$output" >> "$GITHUB_OUTPUT"
          echo "EOF" >> "$GITHUB_OUTPUT"
          if echo "$output" | grep -q "⚠️"; then
            echo "has_findings=true" >> "$GITHUB_OUTPUT"
          else
            echo "has_findings=false" >> "$GITHUB_OUTPUT"
          fi
      - name: Create issue on findings
        if: steps.scan.outputs.has_findings == 'true'
        uses: actions/github-script@v7
        with:
          script: |
            const output = `${{ '{{' }} steps.scan.outputs.scan_output {{ '}}' }}`;
            const today = new Date().toISOString().split('T')[0];
            await github.rest.issues.create({
              owner: context.repo.owner,
              repo: context.repo.repo,
              title: `Harness Entropy Scan - ${today}`,
              body: `## Entropy Scan Results\n\nThe weekly entropy scan found issues that need attention:\n\n\`\`\`\n${output}\n\`\`\`\n\n### How to fix\n\n- **stale-reference**: Update or remove references in AGENTS.md to match current codebase\n- **missing-type-check**: Add \`"type-check": "tsc --noEmit"\` to the package's scripts\n- **console-log**: Replace \`console.log\` with a proper logger\n- **unused-package**: Consider removing packages that are no longer imported\n\nRun \`pnpm scan:entropy\` locally to verify fixes.`,
              labels: ['maintenance', 'harness'],
            });
